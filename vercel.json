{
  "buildCommand": "cd feature-request-board && npm install && npm run build",
  "outputDirectory": "feature-request-board/dist",
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/slack-sync",
      "schedule": "*/5 * * * *"
    }
  ]
}
