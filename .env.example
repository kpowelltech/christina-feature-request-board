# Neon PostgreSQL Database (provided by Vercel)
# Get this from: Vercel Dashboard → Your Project → Storage → Neon Database → Connection String
# Use the "DATABASE_URL" variable that Vercel provides
DATABASE_URL="postgresql://user:password@host/database"

# ============================================
# AUTHENTICATION (Google OAuth - REQUIRED)
# ============================================
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Set Authorized redirect URIs to: http://localhost:5173/api/auth-callback (local) and https://your-domain.vercel.app/api/auth-callback (production)
# 3. Restrict to tapcart.co domain in OAuth consent screen

# Your Google OAuth Client ID
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Your Google OAuth Client Secret (KEEP THIS SECRET!)
GOOGLE_CLIENT_SECRET="your-client-secret"

# Base URL of your application (for OAuth redirects)
# Local: http://localhost:5173
# Production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:5173"

# Secret for signing JWT tokens (generate with: openssl rand -base64 32)
# IMPORTANT: Use a different secret for production!
NEXTAUTH_SECRET="your-random-jwt-secret-minimum-32-characters"

# Auth version (increment to force all users to re-authenticate)
AUTH_VERSION="1"

# ============================================
# OPTIONAL: Slack Integration
# ============================================
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
PRODUCT_CHANNEL_ID="C123456789"
AI_FEEDBACK_CHANNEL_ID="C987654321"
# Slack workspace team ID (for deep-linking into the Slack desktop app)
# Find it at: https://app.slack.com → open workspace → team ID is the T-prefixed value in the URL
VITE_SLACK_TEAM_ID="T0000000000"

# ============================================
# OPTIONAL: Anthropic AI for Slack message parsing
# ============================================
ANTHROPIC_API_KEY="sk-ant-your-api-key"

# ============================================
# VERCEL CRON JOB SECURITY
# ============================================
# Secret token for securing cron endpoints (generate with: openssl rand -base64 32)
# This is automatically used by Vercel to authenticate cron job requests
# Set this in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET="your-random-cron-secret-minimum-32-characters"
